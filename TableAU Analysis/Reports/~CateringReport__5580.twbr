      <column caption='Total Catering Sales' datatype='real' name='[Calculation_0651742352965632]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([FirstPartyNetSales]) + SUM([ThirdPartyNetSales])' />
      </column>
      <column caption='Total Net Sales' datatype='real' name='[Calculation_0651742355304449]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([NetSalesCY])' />
      </column>
      <column caption='Prior Year Sales' datatype='real' name='[Calculation_0651742355468290]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([NetSalesPY])' />
      </column>
      <column caption='YoY Change' datatype='real' name='[Calculation_0651742364401667]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0651742355304449] - [Calculation_0651742355468290]' />
      </column>
      <column caption='YoY %' datatype='real' name='[Calculation_0651742364463108]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0651742355304449] - [Calculation_0651742355468290]) / [Calculation_0651742355468290]' />
      </column>
      <column caption='Catering 1P Sales' datatype='real' name='[Calculation_2115742066196480]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([FirstPartyNetSales])' />
      </column>
      <column caption='Catering 3P Sales' datatype='real' name='[Calculation_2115742066286593]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([ThirdPartyNetSales])' />
      </column>
      <column caption='Variance Color' datatype='string' name='[Calculation_2184188105854976]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([NetSalesCY]) - SUM([ReportedSalesTarget]) &gt;= 0&#13;&#10;THEN &apos;Green&apos;&#13;&#10;ELSE &apos;Red&apos;&#13;&#10;END' />
      </column>
      <column caption='Actual Revenue' datatype='real' name='[Calculation_2184188107919361]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([NetSalesCY])' />
      </column>
      <column caption='Target Revenue' datatype='real' name='[Calculation_2184188107988994]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([ReportedSalesTarget])' />
      </column>
      <column caption='Variance $' datatype='real' name='[Calculation_2184188108136451]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([NetSalesCY]) - SUM([ReportedSalesTarget])' />
      </column>
      <column caption='Variance %' datatype='real' name='[Calculation_2184188108218372]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([NetSalesCY]) - SUM([ReportedSalesTarget])) / SUM([ReportedSalesTarget])' />
      </column>
      <column caption='Variance Icon' datatype='string' name='[Calculation_2184188110749701]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([NetSalesCY]) - SUM([ReportedSalesTarget]) &gt;= 0&#13;&#10;THEN &apos;▲&apos;&#13;&#10;ELSE &apos;▼&apos;&#13;&#10;END' />
      </column>
