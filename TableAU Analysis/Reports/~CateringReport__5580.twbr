    <worksheet name='Matrix table'>
      <table>
        <view>
          <datasources>
            <datasource caption='reported_sales (Multiple Connections)' name='federated.1mp3wna1j4x2lt13vy8md1czclxe' />
          </datasources>
          <datasource-dependencies datasource='federated.1mp3wna1j4x2lt13vy8md1czclxe'>
            <column caption='Brand Name' datatype='string' name='[BrandName]' role='dimension' type='nominal' />
            <column caption='Variance Color' datatype='string' name='[Calculation_2184188105854976]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF SUM([NetSalesCY]) - SUM([ReportedSalesTarget]) &gt;= 0&#13;&#10;THEN &apos;Green&apos;&#13;&#10;ELSE &apos;Red&apos;&#13;&#10;END' />
            </column>
            <column caption='Actual Revenue' datatype='real' name='[Calculation_2184188107919361]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([NetSalesCY])' />
            </column>
            <column caption='Target Revenue' datatype='real' name='[Calculation_2184188107988994]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([ReportedSalesTarget])' />
            </column>
            <column caption='Variance $' datatype='real' name='[Calculation_2184188108136451]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([NetSalesCY]) - SUM([ReportedSalesTarget])' />
            </column>
            <column caption='Variance %' datatype='real' name='[Calculation_2184188108218372]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([NetSalesCY]) - SUM([ReportedSalesTarget])) / SUM([ReportedSalesTarget])' />
            </column>
            <column caption='Variance Icon' datatype='string' name='[Calculation_2184188110749701]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF SUM([NetSalesCY]) - SUM([ReportedSalesTarget]) &gt;= 0&#13;&#10;THEN &apos;▲&apos;&#13;&#10;ELSE &apos;▼&apos;&#13;&#10;END' />
            </column>
            <column caption='Month Name' datatype='string' name='[MonthName]' role='dimension' type='nominal' />
            <column caption='Net Sales CY' datatype='real' name='[NetSalesCY]' role='measure' type='quantitative' />
            <column caption='Reported Sales Target' datatype='real' name='[ReportedSalesTarget]' role='measure' type='quantitative' />
            <column-instance column='[BrandName]' derivation='None' name='[none:BrandName:nk]' pivot='key' type='nominal' />
            <column-instance column='[MonthName]' derivation='None' name='[none:MonthName:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_2184188105854976]' derivation='User' name='[usr:Calculation_2184188105854976:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_2184188107919361]' derivation='User' name='[usr:Calculation_2184188107919361:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2184188107988994]' derivation='User' name='[usr:Calculation_2184188107988994:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2184188108136451]' derivation='User' name='[usr:Calculation_2184188108136451:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2184188108218372]' derivation='User' name='[usr:Calculation_2184188108218372:qk]' pivot='key' type='quantitative' />
